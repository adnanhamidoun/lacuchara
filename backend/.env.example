# ============================================================================
# .env.example - PLANTILLA DE VARIABLES DE ENTORNO
# ============================================================================
# Este archivo es SOLO una referencia. Nunca debe contener valores reales.
#
# EN DESARROLLO: Copia a .env y completa con tus valores locales
# EN PRODUCCIÓN: Usa Azure Key Vault o GitHub Secrets
# EN DOCKER: Las variables vienen del orchestrator (App Service, Compose, etc.)
#
# ============================================================================

# ============================================================================
# BASE DE DATOS (Azure SQL Server)
# ============================================================================
# IMPORTANTE: En Docker, estas vienen de scripts/deploy/azure-deploy.sh o docker-compose.yml
DB_SERVER=your-server.database.windows.net
DB_NAME=your_database_name
DB_USER=your_username
DB_PASS=your_password_here
DB_DRIVER=ODBC Driver 17 for SQL Server

# ============================================================================
# ENTORNO
# ============================================================================
APP_ENV=development
DEBUG=True

# ============================================================================
# API (Uvicorn)
# ============================================================================
API_PORT=8000
API_HOST=0.0.0.0
API_WORKERS=4

# ============================================================================
# CORS (Cross-Origin Resource Sharing)
# ============================================================================
# En desarrollo: * (todos)
# En producción: usar dominio específico
CORS_ORIGINS=*

# ============================================================================
# PATHS (Rutas de archivos/datos)
# ============================================================================
# Estos son automáticos en Docker, pero documentados aquí
ARTIFACTS_PATH=backend/azca/artifacts
STATIC_FILES_PATH=backend/api/static

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============================================================================
# NOTA IMPORTANTE
# ============================================================================
# En Docker/Producción:
# - Las variables de entorno se pasan en runtime
# - NO se incluye este archivo en la imagen
# - Las credenciales vienen de Azure Key Vault
# - Ver docs/docker/DOCKER-DEPLOY.md para instrucciones de deploy



