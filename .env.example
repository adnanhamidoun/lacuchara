# Azure SQL Database Connection (.env.example)
# IMPORTANTE: Copia este archivo a .env y rellena con tus credenciales reales
# NUNCA hagas commit del archivo .env real - está en .gitignore para proteger secretos

# Azure SQL Server
DB_SERVER=azcasqlserver.database.windows.net
DB_NAME=azca_db
DB_USER=azca_user
DB_PASSWORD=tu_password_aqui_no_comprometido
DB_DRIVER={ODBC Driver 17 for SQL Server}

# Configuración de la aplicación
ENVIRONMENT=development
DEBUG=False

# Configuración opcional para OpenAI / LLM (si aplica)
# OPENAI_API_KEY=tu_api_key_aqui
# OPENAI_MODEL=gpt-4
