# Azure SQL Database Connection (.env.example)
# IMPORTANTE: Copia este archivo a .env y rellena con tus credenciales reales
# NUNCA hagas commit del archivo .env real - está en .gitignore para proteger secretos

# Azure SQL Database Connection
DB_SERVER=azcasqlserver.database.windows.net
DB_NAME=azca_db
DB_USER=azca_user
DB_PASS=tu_password_aqui_no_comprometido
DB_DRIVER={ODBC Driver 17 for SQL Server}

# Configuración de la aplicación
ENVIRONMENT=development
DEBUG=False

# Azure Document Intelligence (para OCR de menús)
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_KEY=tu_document_intelligence_key_aqui
AZURE_DOCUMENT_INTELLIGENCE_MODEL_ID=prebuilt-layout

# Credenciales de administrador
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=tu_admin_password_aqui

# Azure Storage Configuration (para fotos de restaurantes)
AZURE_STORAGE_ACCOUNT_NAME=tu_storage_account_name
AZURE_STORAGE_ACCOUNT_KEY=tu_storage_account_key_aqui
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=tu_storage_account_name;AccountKey=tu_storage_account_key_aqui;EndpointSuffix=core.windows.net
AZURE_BLOB_CONTAINER_NAME=restaurant-profiles

